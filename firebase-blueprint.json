{
  "entities": {
    "StudyNote": {
      "title": "StudyNote",
      "description": "User created and synchronized study notes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userEmail": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "subject": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "summaryPoints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "flashcards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "front": { "type": "string" },
              "back": { "type": "string" }
            }
          }
        },
        "attachmentUrl": { "type": "string" },
        "attachmentName": { "type": "string" },
        "attachmentType": { "type": "string" }
      },
      "required": ["id", "userEmail", "title", "content", "subject", "timestamp"]
    },
    "BoardPrepPaper": {
      "title": "BoardPrepPaper",
      "description": "User uploaded board preparation papers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uploaderEmail": { "type": "string" },
        "uploaderName": { "type": "string" },
        "board": { "type": "string" },
        "year": { "type": "number" },
        "subjectEn": { "type": "string" },
        "subjectBn": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uploaderEmail", "uploaderName", "board", "year", "subjectEn", "subjectBn", "timestamp"]
    }
  },
  "firestore": {
    "/notes/{noteId}": {
      "schema": "StudyNote",
      "description": "Personal study notes collection grouped by user identity"
    },
    "/boardPrepPapers/{paperId}": {
      "schema": "BoardPrepPaper",
      "description": "Collection of previous 4 years board exam papers uploaded by students and admins"
    }
  }
}
